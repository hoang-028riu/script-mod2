-- ⚙️ Logic
local autoTele = false
local currentIndex = 1
local followConn = nil

local function getCharHRP()
	local char = player.Character or player.CharacterAdded:Wait()
	local hrp = char:WaitForChild("HumanoidRootPart")
	return char, hrp
end

local function getAlivePlayers()
	local list = {}
	for _, plr in pairs(Players:GetPlayers()) do
		if plr ~= player and plr.Character and plr.Character:FindFirstChild("HumanoidRootPart") then
			local hum = plr.Character:FindFirstChildOfClass("Humanoid")
			if hum and hum.Health > 0 then
				table.insert(list, plr)
			end
		end
	end
	return list
end

local function startFollow(targetPlayer)
	if followConn then
		followConn:Disconnect()
		followConn = nil
	end

	local _, myHRP = getCharHRP()
	local targetChar = targetPlayer.Character
	if not targetChar then return end
	local targetHRP = targetChar:FindFirstChild("HumanoidRootPart")
	if not targetHRP then return end

	local dist = tonumber(distBox.Text) or 5
	local up = tonumber(upBox.Text) or 1.5

	followConn = RunService.RenderStepped:Connect(function()
		if not autoTele or not targetChar or not targetHRP or not targetHRP.Parent then
			return
		end

		-- Giữ vị trí sau lưng đối thủ
		local behind = -targetHRP.CFrame.LookVector * dist
		local newPos = targetHRP.Position + behind + Vector3.new(0, up, 0)
		myHRP.CFrame = CFrame.new(newPos, targetHRP.Position)

		-- ✅ Chỉ xoay nhân vật của bạn hướng về kẻ địch
		local char = player.Character
		if char and char:FindFirstChild("HumanoidRootPart") then
			local hrp = char.HumanoidRootPart
			local lookAt = (targetHRP.Position - hrp.Position).Unit
			local newCFrame = CFrame.new(hrp.Position, hrp.Position + lookAt)
			hrp.CFrame = newCFrame
		end
	end)
end

local function teleLoop()
	while autoTele do
		local players = getAlivePlayers()
		if #players == 0 then
			autoTele = false
			toggle.Text = "Bật Auto Tele (Q)"
			toggle.BackgroundColor3 = Color3.fromRGB(60,120,60)
			break
		end

		if currentIndex > #players then
			currentIndex = 1
		end

		local target = players[currentIndex]
		if target then
			startFollow(target)
		end

		currentIndex += 1
		local interval = tonumber(intervalBox.Text) or 0.5
		local elapsed = 0
		while elapsed < interval do
			if not autoTele then return end
			elapsed += RunService.Heartbeat:Wait()
		end
	end
end

local function toggleTele()
	if autoTele then
		autoTele = false
		if followConn then
			followConn:Disconnect()
			followConn = nil
		end
		toggle.Text = "Bật Auto Tele (Q)"
		toggle.BackgroundColor3 = Color3.fromRGB(60,120,60)
	else
		autoTele = true
		toggle.Text = "Tắt Auto Tele"
		toggle.BackgroundColor3 = Color3.fromRGB(160,60,60)
		task.spawn(teleLoop)
	end
end

toggle.MouseButton1Click:Connect(toggleTele)

UserInputService.InputBegan:Connect(function(input, gp)
	if gp then return end
	if input.KeyCode == Enum.KeyCode.Q then
		toggleTele()
	end
end)

print("✅ Auto Tele + Quay nhân vật về hướng địch (không xoay camera).")
