-- Draggable GUI
local dragging, dragStart, startPos
MainFrame.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        dragging = true
        dragStart = input.Position
        startPos = MainFrame.Position
        input.Changed:Connect(function()
            if input.UserInputState == Enum.UserInputState.End then dragging = false end
        end)
    end
end)
UserInputService.InputChanged:Connect(function(input)
    if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
        local delta = input.Position - dragStart
        MainFrame.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
    end
end)

-- Đổi key
KeyBox.FocusLost:Connect(function()
    local keyStr = KeyBox.Text:upper()
    local key = Enum.KeyCode[keyStr]
    if key then
        getgenv().ToggleKey = key
        Status.Text = "Key: " .. keyStr
        Status.TextColor3 = Color3.fromRGB(0, 255, 0)
    else
        KeyBox.Text = getgenv().ToggleKey.Name
        Status.Text = "Key invalid!"
        Status.TextColor3 = Color3.fromRGB(255, 0, 0)
    end
end)

-- Functions
local function StartEffects()
    if not Player.Character or not Player.Character:FindFirstChild("HumanoidRootPart") then return end
    BaseMyCFrame = Player.Character.HumanoidRootPart.CFrame
    RelativePositions = {}
    
    -- Init relative pos cho players hiện tại
    for _, plr in ipairs(Players:GetPlayers()) do
        if plr ~= Player and plr.Character and plr.Character:FindFirstChild("HumanoidRootPart") then
            local root = plr.Character.HumanoidRootPart
            RelativePositions[plr] = BaseMyCFrame:ToObjectSpace(root.CFrame)
        end
    end
    
    -- Hitbox expander loop
    HitboxConnection = RunService.Heartbeat:Connect(function()
        for _, plr in ipairs(Players:GetPlayers()) do
            if plr ~= Player and plr.Character and plr.Character:FindFirstChild("Head") then
                local head = plr.Character.Head
                head.Size = Vector3.new(getgenv().HitboxSize, getgenv().HitboxSize, getgenv().HitboxSize)
                head.Transparency = 0.4
                head.CanCollide = false
                head.Material = Enum.Material.ForceField  -- Glow effect
            end
        end
    end)
    
    -- Freeze relative loop
    FreezeConnection = RunService.Heartbeat:Connect(function()
        if not Player.Character or not Player.Character:FindFirstChild("HumanoidRootPart") then return end
        local myRoot = Player.Character.HumanoidRootPart.CFrame
        for plr, relCFrame in pairs(RelativePositions) do
            if plr.Character and plr.Character:FindFirstChild("HumanoidRootPart") then
                local root = plr.Character.HumanoidRootPart
                root.CFrame = myRoot * relCFrame
            end
        end
        -- New players
        for _, plr in ipairs(Players:GetPlayers()) do
            if plr ~= Player and not RelativePositions[plr] and plr.Character and plr.Character:FindFirstChild("HumanoidRootPart") then
                RelativePositions[plr] = BaseMyCFrame:ToObjectSpace(plr.Character.HumanoidRootPart.CFrame)
            end
        end
    end)
end

local function StopEffects()
    if HitboxConnection then HitboxConnection:Disconnect(); HitboxConnection = nil end
    if FreezeConnection then FreezeConnection:Disconnect(); FreezeConnection = nil end
    
    -- Restore hitbox (approx)
    for _, plr in ipairs(Players:GetPlayers()) do
        if plr.Character then
            local head = plr.Character:FindFirstChild("Head")
            if head then
                head.Size = Vector3.new(2, 1, 1)
                head.Transparency = 0
                head.Material = Enum.Material.SmoothPlastic
            end
        end
    end
    
    RelativePositions = {}
    BaseMyCFrame = nil
end

-- Toggle
local function Toggle()
    if getgenv().Enabled then
        StopEffects()
        getgenv().Enabled = false
        ToggleBtn.Text = "ON/OFF (E)"
        ToggleBtn.BackgroundColor3 = Color3.fromRGB(0, 170, 255)
        Status.Text = "OFF - Ready"
        Status.TextColor3 = Color3.fromRGB(255, 0, 0)
    else
        StartEffects()
        getgenv().Enabled = true
        ToggleBtn.Text = "ON (E to OFF)"
        ToggleBtn.BackgroundColor3 = Color3.fromRGB(255, 100, 0)
        Status.Text = "ON - Hitbox + Freeze Active"
        Status.TextColor3 = Color3.fromRGB(0, 255, 0)
    end
end

ToggleBtn.MouseButton1Click:Connect(Toggle)

-- Keybind
UserInputService.InputBegan:Connect(function(input, gp)
    if gp then return end
    if input.KeyCode == getgenv().ToggleKey then
        Toggle()
    end
end)

-- Respawn/Death reset
Player.CharacterRemoving:Connect(function()
    getgenv().Enabled = false
    StopEffects()
    ToggleBtn.Text = "ON/OFF (E)"
    ToggleBtn.BackgroundColor3 = Color3.fromRGB(0, 170, 255)
    Status.Text = "OFF - Respawned"
    Status.TextColor3 = Color3.fromRGB(255, 0, 0)
end)

Player.CharacterAdded:Connect(function()
    task.wait(1)  -- Wait load
    if getgenv().Enabled then
        task.wait(1)
        StartEffects()
    end
end)

