hitBtn.Position = UDim2.new(0,10,0,235)
hitBtn.Text = "💥 ĐÂM!"
hitBtn.BackgroundColor3 = Color3.fromRGB(120,0,0)
hitBtn.TextColor3 = Color3.new(1,1,1)
hitBtn.Font = Enum.Font.SourceSansBold
hitBtn.TextScaled = true

local autoBtn = Instance.new("TextButton", frame)
autoBtn.Size = UDim2.new(1, -20, 0, 35)
autoBtn.Position = UDim2.new(0,10,0,270)
autoBtn.Text = "🔁 AUTO: TẮT"
autoBtn.BackgroundColor3 = Color3.fromRGB(0,100,0)
autoBtn.TextColor3 = Color3.new(1,1,1)
autoBtn.Font = Enum.Font.SourceSansBold
autoBtn.TextScaled = true

-- Chức năng đâm
local auto = false

local function knockTarget(targetChar, speed)
	local char = LocalPlayer.Character
	if not char then return end
	local hrp = char:FindFirstChild("HumanoidRootPart")
	if not hrp then return end
	local targetHRP = targetChar:FindFirstChild("HumanoidRootPart")
	if not targetHRP then return end

	local dir = (targetHRP.Position - hrp.Position).Unit
	hrp.Velocity = dir * speed
	task.wait(0.1)
	targetHRP.Velocity = dir * speed * 1.3 + Vector3.new(0, speed * 0.4, 0)
end

local function teleportAround(targetHRP)
	local hrp = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
	if not hrp then return end
	local offset = Vector3.new(math.random(-30,30), 0, math.random(-30,30))
	hrp.CFrame = CFrame.new(targetHRP.Position + offset)
end

hitBtn.MouseButton1Click:Connect(function()
	local target = dropdown:GetAttribute("Target")
	local speed = tonumber(speedBox.Text) or 200
	if not target then return end

	if target == "All" then
		for _,plr in pairs(Players:GetPlayers()) do
			if plr ~= LocalPlayer and plr.Character then
				knockTarget(plr.Character, speed)
			end
		end
	else
		local targetPlr = Players:FindFirstChild(target)
		if targetPlr and targetPlr.Character then
			knockTarget(targetPlr.Character, speed)
		end
	end
end)

autoBtn.MouseButton1Click:Connect(function()
	auto = not auto
	autoBtn.Text = auto and "🔁 AUTO: BẬT" or "🔁 AUTO: TẮT"
	while auto do
		local target = dropdown:GetAttribute("Target")
		local speed = tonumber(speedBox.Text) or 200
		if target and target ~= "All" then
			local plr = Players:FindFirstChild(target)
			if plr and plr.Character and LocalPlayer.Character then
				local hrp = plr.Character:FindFirstChild("HumanoidRootPart")
				if hrp then
					knockTarget(plr.Character, speed)
					task.wait(0.2)
					teleportAround(hrp)
				end
			end
		elseif target == "All" then
			for _,plr in pairs(Players:GetPlayers()) do
				if plr ~= LocalPlayer and plr.Character then
					local hrp = plr.Character:FindFirstChild("HumanoidRootPart")
					if hrp then
						knockTarget(plr.Character, speed)
						task.wait(0.1)
						teleportAround(hrp)
					end
				end
			end
		end
		task.wait(0.3)
	end
end)

print("✅ Phi người chơi GUI + Auto Mode đã chạy (LocalScript)")
