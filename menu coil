-- Hệ thống thanh kéo (Slider)
local activeSliders = {}
local function createSlider(labelText, minVal, maxVal, defaultVal, isFloat)
    local frame = Instance.new("Frame")
    frame.Size = UDim2.new(1, 0, 0, 40)
    frame.BackgroundTransparency = 1
    frame.Parent = sliderContainer

    local lbl = Instance.new("TextLabel")
    lbl.Size = UDim2.new(1, 0, 0, 15)
    lbl.BackgroundTransparency = 1
    lbl.TextColor3 = Color3.fromRGB(220, 220, 220)
    lbl.Font = Enum.Font.Gotham
    lbl.TextSize = 12
    lbl.TextXAlignment = Enum.TextXAlignment.Left
    lbl.Parent = frame

    local bg = Instance.new("TextButton")
    bg.Size = UDim2.new(1, 0, 0, 15)
    bg.Position = UDim2.new(0, 0, 0, 20)
    bg.Text = ""
    bg.BackgroundColor3 = Color3.fromRGB(50, 50, 50)
    bg.AutoButtonColor = false
    bg.Parent = frame
    Instance.new("UICorner", bg).CornerRadius = UDim.new(0, 5)

    local fill = Instance.new("Frame")
    local initialPct = (defaultVal - minVal) / (maxVal - minVal)
    fill.Size = UDim2.new(initialPct, 0, 1, 0)
    fill.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
    fill.Parent = bg
    Instance.new("UICorner", fill).CornerRadius = UDim.new(0, 5)

    local val = defaultVal
    local isDragging = false

    local function updateText()
        if isFloat then lbl.Text = labelText .. ": " .. string.format("%.2f", val) else lbl.Text = labelText .. ": " .. math.floor(val) end
    end
    updateText()

    local function updateSlider(input)
        local relativeX = math.clamp((input.Position.X - bg.AbsolutePosition.X) / bg.AbsoluteSize.X, 0, 1)
        fill.Size = UDim2.new(relativeX, 0, 1, 0)
        val = minVal + (maxVal - minVal) * relativeX
        if not isFloat then val = math.floor(val) else val = math.floor(val * 100) / 100 end
        updateText()
    end

    bg.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then isDragging = true; updateSlider(input) end
    end)
    uis.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then isDragging = false end
    end)
    uis.InputChanged:Connect(function(input)
        if isDragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then updateSlider(input) end
    end)

    return function() return val end
end

local currentRefreshCallback = nil

local function showConfigUI(toolName, slidersConfig, applyCallback)
    for _, child in pairs(sliderContainer:GetChildren()) do
        if child:IsA("Frame") then child:Destroy() end
    end
    activeSliders = {}
    titleLbl.Text = toolName
    for _, cfg in ipairs(slidersConfig) do
        local getValueFunc = createSlider(cfg.name, cfg.min, cfg.max, cfg.default, cfg.isFloat)
        activeSliders[cfg.id] = getValueFunc
    end
    currentRefreshCallback = applyCallback
    configFrame.Visible = true
end

local function hideConfigUI()
    configFrame.Visible = false
    currentRefreshCallback = nil
end

refreshBtn.MouseButton1Click:Connect(function()
    if currentRefreshCallback then
        local values = {}
        for id, getFunc in pairs(activeSliders) do values[id] = getFunc() end
        currentRefreshCallback(values)
    end
end)

