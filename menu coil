-- 9. Fly Coil
local flySpeed = 50
local function spawnFlyCoil()
    local t9 = Instance.new("Tool"); t9.Name = "9. Fly Coil"; t9.RequiresHandle = true
    local h9 = Instance.new("Part"); h9.Name = "Handle"; h9.Size = Vector3.new(0.5, 0.5, 0.5); h9.Color = Color3.fromRGB(255, 215, 0); h9.Parent = t9; applyMesh(h9)
    local flyConn, bv, bg
    local function setupFly()
        local char = player.Character; if not char then return end
        local root = char:WaitForChild("HumanoidRootPart")
        if not bv then
            bv = Instance.new("BodyVelocity", root); bv.MaxForce = Vector3.new(100000, 100000, 100000); bv.Velocity = Vector3.zero
            bg = Instance.new("BodyGyro", root); bg.MaxTorque = Vector3.new(100000, 100000, 100000); bg.D = 50
        end
        char.Humanoid.PlatformStand = true
        if flyConn then flyConn:Disconnect() end
        flyConn = runService.RenderStepped:Connect(function()
            local cam = workspace.CurrentCamera
            bg.CFrame = cam.CFrame
            local moveDir = Vector3.zero
            if uis:IsKeyDown(Enum.KeyCode.W) then moveDir = moveDir + cam.CFrame.LookVector end
            if uis:IsKeyDown(Enum.KeyCode.S) then moveDir = moveDir - cam.CFrame.LookVector end
            if uis:IsKeyDown(Enum.KeyCode.A) then moveDir = moveDir - cam.CFrame.RightVector end
            if uis:IsKeyDown(Enum.KeyCode.D) then moveDir = moveDir + cam.CFrame.RightVector end
            if moveDir.Magnitude > 0 then bv.Velocity = moveDir.Unit * flySpeed else bv.Velocity = Vector3.zero end
        end)
    end
    t9.Equipped:Connect(function()
        setupFly()
        showConfigUI("Cấu Hình: Fly Coil", { {id = "fly", name = "Tốc Độ Bay", min = 10, max = 300, default = flySpeed, isFloat = false} }, 
        function(vals) flySpeed = vals.fly end)
    end)
    t9.Unequipped:Connect(function()
        hideConfigUI()
        if flyConn then flyConn:Disconnect() end
        if bv then bv:Destroy(); bv = nil end
        if bg then bg:Destroy(); bg = nil end
        if player.Character then player.Character.Humanoid.PlatformStand = false end
    end)
    t9.Parent = player.Backpack
end

