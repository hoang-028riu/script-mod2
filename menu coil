-- 2. Gravity Coil
local gravJumpVal, gravLiftVal = 100, 0.6
local gravForce
local function spawnGravityCoil()
    local t2 = Instance.new("Tool"); t2.Name = "2. Gravity Coil"; t2.RequiresHandle = true
    local h2 = Instance.new("Part"); h2.Name = "Handle"; h2.Size = Vector3.new(0.5, 0.5, 0.5); h2.Color = Color3.fromRGB(50, 205, 50); h2.Parent = t2; applyMesh(h2)
    local function applyGravity(jump, lift)
        local char = player.Character
        if char and char:FindFirstChild("Humanoid") then
            char.Humanoid.UseJumpPower = true; char.Humanoid.JumpPower = jump
            if gravForce then gravForce:Destroy() end
            if lift > 0 then
                gravForce = Instance.new("BodyForce")
                local totalMass = 0
                for _, p in pairs(char:GetChildren()) do if p:IsA("BasePart") then totalMass = totalMass + p:GetMass() end end
                gravForce.Force = Vector3.new(0, totalMass * workspace.Gravity * lift, 0)
                gravForce.Parent = char:WaitForChild("HumanoidRootPart")
            end
        end
    end
    t2.Equipped:Connect(function()
        applyGravity(gravJumpVal, gravLiftVal)
        showConfigUI("Cấu Hình: Gravity Coil", {
            {id = "jump", name = "Lực Nhảy", min = 50, max = 300, default = gravJumpVal, isFloat = false},
            {id = "lift", name = "Lực Rơi Chậm", min = 0, max = 1.2, default = gravLiftVal, isFloat = true}
        }, function(vals) gravJumpVal = vals.jump; gravLiftVal = vals.lift; applyGravity(gravJumpVal, gravLiftVal) end)
    end)
    t2.Unequipped:Connect(function() hideConfigUI(); applyGravity(50, 0) end)
    t2.Parent = player.Backpack
end

