-- ==========================================
-- 2. HÀM XỬ LÝ CHỐNG NGỒI
-- ==========================================
local function updateAntiSitState(character)
    if not character then return end
    
    local humanoid = character:WaitForChild("Humanoid", 5)
    if humanoid then
        if isAntiSitEnabled then
            -- Tắt trạng thái Seated (Ngồi) của Humanoid
            humanoid:SetStateEnabled(Enum.HumanoidStateType.Seated, false)
            
            -- Nếu đang ngồi trước khi bật, ép nhân vật đứng dậy
            if humanoid.Sit then
                humanoid.Sit = false
                humanoid.Jump = true
            end
        else
            -- Bật lại trạng thái Seated để có thể ngồi bình thường
            humanoid:SetStateEnabled(Enum.HumanoidStateType.Seated, true)
        end
    end
end

-- ==========================================
-- 3. XỬ LÝ SỰ KIỆN NÚT BẤM & HỒI SINH
-- ==========================================
ToggleButton.MouseButton1Click:Connect(function()
    isAntiSitEnabled = not isAntiSitEnabled -- Đảo ngược trạng thái
    
    if isAntiSitEnabled then
        ToggleButton.Text = "Chống Ngồi: BẬT"
        ToggleButton.BackgroundColor3 = Color3.fromRGB(85, 255, 85) -- Màu xanh lá
    else
        ToggleButton.Text = "Chống Ngồi: TẮT"
        ToggleButton.BackgroundColor3 = Color3.fromRGB(255, 85, 85) -- Màu đỏ
    end
    
    -- Cập nhật trạng thái cho nhân vật hiện tại
    updateAntiSitState(LocalPlayer.Character)
end)

-- Khi nhân vật hồi sinh hoặc thay đổi, áp dụng lại trạng thái cài đặt
LocalPlayer.CharacterAdded:Connect(function(newCharacter)
    -- Đợi một chút để Humanoid load đầy đủ
    task.wait(0.5) 
    updateAntiSitState(newCharacter)
end)

-- Khởi chạy lần đầu cho nhân vật nếu đã spawn
if LocalPlayer.Character then
    updateAntiSitState(LocalPlayer.Character)
end
