local ESP_Folder = Instance.new("Folder")
ESP_Folder.Name = "ProESP_Storage"
ESP_Folder.Parent = game.CoreGui -- Để ẩn khỏi workspace game (anti-detection nhẹ)

-- Hàm xóa sạch ESP cũ
local function clearESP()
	ESP_Folder:ClearAllChildren()
end

-- Hàm tạo Highlight cho vật thể
local function highlightObject(obj)
	-- Kiểm tra nếu đã có ESP rồi thì thôi
	if obj:FindFirstChild("HasESP_Tag") then return end
	
	-- Tạo Highlight (Nhìn xuyên tường tốt nhất hiện nay)
	local hl = Instance.new("Highlight")
	hl.Name = "ProESP_Highlight"
	hl.Adornee = obj
	hl.FillColor = Color3.fromRGB(255, 50, 50) -- Màu đỏ bên trong
	hl.FillTransparency = 0.5
	hl.OutlineColor = Color3.fromRGB(255, 255, 255) -- Viền trắng
	hl.OutlineTransparency = 0
	hl.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop -- QUAN TRỌNG: Nhìn xuyên tường
	hl.Parent = ESP_Folder
	
	-- BillboardGui để hiện tên (Optional - cho ngầu)
	local bb = Instance.new("BillboardGui")
	bb.Adornee = obj
	bb.Size = UDim2.new(0,100,0,50)
	bb.StudsOffset = Vector3.new(0,2,0)
	bb.AlwaysOnTop = true
	bb.Parent = ESP_Folder
	
	local txt = Instance.new("TextLabel", bb)
	txt.Size = UDim2.new(1,0,1,0)
	txt.BackgroundTransparency = 1
	txt.Text = obj.Name
	txt.TextColor3 = Color3.new(1,1,0)
	txt.TextStrokeTransparency = 0
	txt.Font = Enum.Font.GothamBold
	txt.TextSize = 12
end

-- Hàm quét và áp dụng
ScanBtn.MouseButton1Click:Connect(function()
	clearESP() -- Xóa cũ trước khi tìm mới
	
	-- 1. Lấy danh sách từ khóa từ các ô TextBox
	local keywords = {}
	for _, child in pairs(ScrollFrame:GetChildren()) do
		if child:IsA("Frame") then -- Mỗi dòng là 1 Frame
			local box = child:FindFirstChild("TextBox")
			if box and box.Text ~= "" then
				table.insert(keywords, string.lower(box.Text)) -- Lưu dạng chữ thường để so sánh
			end
		end
	end
	
	if #keywords == 0 then return end -- Không nhập gì thì thôi
	
	-- 2. Quét toàn bộ workspace
	local count = 0
	for _, obj in pairs(workspace:GetDescendants()) do
		if obj:IsA("BasePart") or obj:IsA("MeshPart") then
			local objNameLow = string.lower(obj.Name)
			
			-- Kiểm tra xem tên vật có chứa bất kỳ từ khóa nào không
			for _, key in pairs(keywords) do
				-- SỬ DỤNG STRING.FIND ĐỂ TÌM 1 PHẦN TÊN (VD: "táo" khớp "táo vàng")
				if string.find(objNameLow, key) then
					highlightObject(obj)
					count = count + 1
					break -- Đã tìm thấy khớp 1 từ khóa, không cần check từ khóa khác cho vật này nữa
				end
			end
		end
	end
	
	ScanBtn.Text = "Đã tìm thấy: " .. count .. " vật!"
	task.delay(2, function()
		ScanBtn.Text = "👁 BẬT/CẬP NHẬT ESP"
	end)
end)

