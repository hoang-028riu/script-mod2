-- Hàm tạo nút chuẩn
local function createButton(text, color, layoutOrder)
	local btn = Instance.new("TextButton")
	btn.Size = UDim2.new(0.9,0,0,35)
	-- Sắp xếp vị trí dựa trên layoutOrder thủ công vì Parent là Frame thường
	if layoutOrder == 1 then
		btn.Position = UDim2.new(0.05,0,0.1,0)
	elseif layoutOrder == 2 then
		btn.Position = UDim2.new(0.05,0,0.55,0)
	end
	
	btn.Text = text
	btn.Font = Enum.Font.GothamBold
	btn.TextColor3 = Color3.new(1,1,1)
	btn.BackgroundColor3 = color
	btn.Parent = BottomContainer
	Instance.new("UICorner", btn).CornerRadius = UDim.new(0,8)
	return btn
end

