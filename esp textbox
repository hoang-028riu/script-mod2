local function createInputRow(defaultText)
	local rowFrame = Instance.new("Frame")
	rowFrame.Size = UDim2.new(0.95, 0, 0, 40)
	rowFrame.BackgroundColor3 = Color3.fromRGB(35,35,45)
	rowFrame.Parent = ScrollFrame
	Instance.new("UICorner", rowFrame).CornerRadius = UDim.new(0,8)
	
	-- Ô nhập tên
	local box = Instance.new("TextBox")
	box.Size = UDim2.new(0.75, 0, 1, 0)
	box.Position = UDim2.new(0, 10, 0, 0)
	box.BackgroundTransparency = 1
	box.TextXAlignment = Enum.TextXAlignment.Left
	box.PlaceholderText = "Nhập tên (VD: Táo)..."
	box.Text = defaultText or ""
	box.TextColor3 = Color3.new(1,1,1)
	box.TextSize = 14
	box.Font = Enum.Font.Gotham
	box.Parent = rowFrame
	
	-- Nút Xóa (X)
	local delBtn = Instance.new("TextButton")
	delBtn.Size = UDim2.new(0, 30, 0, 30)
	delBtn.AnchorPoint = Vector2.new(1, 0.5)
	delBtn.Position = UDim2.new(1, -5, 0.5, 0)
	delBtn.Text = "X"
	delBtn.TextColor3 = Color3.fromRGB(255,80,80)
	delBtn.BackgroundColor3 = Color3.fromRGB(50,30,30)
	delBtn.Font = Enum.Font.GothamBold
	delBtn.Parent = rowFrame
	Instance.new("UICorner", delBtn).CornerRadius = UDim.new(0,6)
	
	delBtn.MouseButton1Click:Connect(function()
		rowFrame:Destroy()
	end)
	
	return box
end

