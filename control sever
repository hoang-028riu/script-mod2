local TimerRunning = false
local StartTimerBtn = Instance.new("TextButton")
StartTimerBtn.Size = UDim2.new(1, -20, 0, 35)
StartTimerBtn.Position = UDim2.new(0, 10, 0, 120)
StartTimerBtn.BackgroundColor3 = Color3.fromRGB(0, 120, 215)
StartTimerBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
StartTimerBtn.Font = Enum.Font.GothamBold
StartTimerBtn.TextSize = 14
StartTimerBtn.Text = "Bắt Đầu Hẹn Giờ Server Hop"
StartTimerBtn.Parent = MainFrame

local TimerBtnCorner = Instance.new("UICorner")
TimerBtnCorner.CornerRadius = UDim.new(0, 4)
TimerBtnCorner.Parent = StartTimerBtn

StartTimerBtn.MouseButton1Click:Connect(function()
    if TimerRunning then
        TimerRunning = false
        StartTimerBtn.Text = "Bắt Đầu Hẹn Giờ Server Hop"
        StartTimerBtn.BackgroundColor3 = Color3.fromRGB(0, 120, 215)
        StatusLabel.Text = "Đã hủy đếm ngược."
        return
    end

    local timeValue = tonumber(TimeInput.Text)
    if not timeValue or timeValue <= 0 then
        StatusLabel.Text = "Vui lòng nhập số hợp lệ!"
        return
    end

    TimerRunning = true
    StartTimerBtn.Text = "Hủy Hẹn Giờ"
    StartTimerBtn.BackgroundColor3 = Color3.fromRGB(200, 50, 50)
    
    local totalSeconds = isMinutes and (timeValue * 60) or timeValue
    
    -- Vòng lặp đếm ngược
    task.spawn(function()
        for i = totalSeconds, 1, -1 do
            if not TimerRunning then break end
            StatusLabel.Text = "Sẽ Server Hop sau: " .. i .. " giây"
            task.wait(1)
        end
        
        if TimerRunning then
            TimerRunning = false
            StartTimerBtn.Text = "Bắt Đầu Hẹn Giờ Server Hop"
            StartTimerBtn.BackgroundColor3 = Color3.fromRGB(0, 120, 215)
            PerformServerHop()
        end
    end)
end)

