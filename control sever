-- Logic Server Hop
local function PerformServerHop()
    StatusLabel.Text = "Đang tìm server để Hop..."
    local httprequest = (syn and syn.request) or (http and http.request) or http_request or (fluxus and fluxus.request) or request
    if httprequest then
        local url = "https://games.roblox.com/v1/games/" .. game.PlaceId .. "/servers/Public?sortOrder=Desc&limit=100"
        local response = httprequest({
            Url = url,
            Method = "GET"
        })
        
        if response.Body then
            local data = HttpService:JSONDecode(response.Body)
            local servers = {}
            if data and data.data then
                for _, v in pairs(data.data) do
                    if type(v) == "table" and v.maxPlayers > v.playing and v.id ~= game.JobId then
                        table.insert(servers, v.id)
                    end
                end
            end
            
            if #servers > 0 then
                local randomServer = servers[math.random(1, #servers)]
                StatusLabel.Text = "Đang kết nối sang server khác..."
                TeleportService:TeleportToPlaceInstance(game.PlaceId, randomServer, LocalPlayer)
            else
                StatusLabel.Text = "Không tìm thấy server phù hợp!"
            end
        else
            StatusLabel.Text = "Lỗi khi lấy danh sách server!"
        end
    else
        StatusLabel.Text = "Exploit của bạn không hỗ trợ http request!"
    end
end

-- Logic Rejoin
local function PerformRejoin()
    StatusLabel.Text = "Đang Rejoin lại server hiện tại..."
    if #Players:GetPlayers() <= 1 then
        LocalPlayer:Kick("\nRejoining...")
        task.wait()
        TeleportService:Teleport(game.PlaceId, LocalPlayer)
    else
        TeleportService:TeleportToPlaceInstance(game.PlaceId, game.JobId, LocalPlayer)
    end
end

