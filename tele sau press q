-- 🧍‍♂️ Check model có phải nhân vật thật
local function isCharacterModel(model)
	if not model or not model:IsA("Model") then return false end
	local humanoid = model:FindFirstChildOfClass("Humanoid")
	local hrp = model:FindFirstChild("HumanoidRootPart")
	if not humanoid or not hrp then return false end
	local hasBody = model:FindFirstChild("Head") or model:FindFirstChild("UpperTorso") or model:FindFirstChild("Torso")
	if not hasBody then return false end
	for _, p in pairs(game.Players:GetPlayers()) do
		if p.Character == model then return true end
	end
	return false
end

-- 🔍 Tìm trong FOV (Đã cập nhật logic Team Check)
local function getClosestInFOV()
	local _, myHRP = getChar()
	local myTeam = player.Team
	local closest, closestDist = nil, math.huge
	local fovRadius = tonumber(fovBox.Text) or 150
	local screenCenter = Vector2.new(camera.ViewportSize.X/2, camera.ViewportSize.Y/2)

	for _, other in pairs(game.Players:GetPlayers()) do
		if other ~= player and other.Character and isCharacterModel(other.Character) then
			
			-- Logic Team Check mới
			local canTarget = true
			if teamCheckEnabled then
				-- Nếu bật check team và cùng team thì bỏ qua
				if other.Team == myTeam and myTeam ~= nil then
					canTarget = false
				end
			end

			if canTarget then
				local hrp = other.Character:FindFirstChild("HumanoidRootPart")
				if hrp then
					local screenPos, onScreen = camera:WorldToViewportPoint(hrp.Position)
					if onScreen then
						local diff = Vector2.new(screenPos.X, screenPos.Y) - screenCenter
						if diff.Magnitude <= fovRadius then
							local dist = (hrp.Position - myHRP.Position).Magnitude
							if dist < closestDist then
								closestDist = dist
								closest = hrp
							end
						end
					end
				end
			end
		end
	end
	return closest
end

-- ⚙️ Theo mục tiêu
local currentTarget = nil
local autoFollow = false
local followConn = nil

local function startFollow(target)
	local _, myHRP = getChar()
	local offset = tonumber(distBox.Text) or 5
	autoFollow = true
	currentTarget = target
	if followConn then followConn:Disconnect() end

	followConn = runService.RenderStepped:Connect(function()
		if not autoFollow or not currentTarget or not currentTarget.Parent or not isCharacterModel(currentTarget.Parent) then
			if followConn then followConn:Disconnect() followConn = nil end
			return
		end
		local offset = tonumber(distBox.Text) or 5
		local t = currentTarget
		local backVec = t.CFrame.LookVector * -offset
		local targetPos = t.Position + backVec
		
		-- ⚡ Tele ra sau mục tiêu (Dùng CFrame để mượt hơn)
		myHRP.CFrame = CFrame.new(targetPos, t.Position)
		-- 🔁 Xoay người theo hướng mục tiêu
		myHRP.CFrame = CFrame.new(myHRP.Position, myHRP.Position + t.CFrame.LookVector)
	end)
end

-- 🧩 Toggle phím
uis.InputBegan:Connect(function(input, gpe)
	if gpe then return end
	if input.KeyCode == Enum.KeyCode[keyBox.Text:upper()] then
		if autoFollow then
			-- Tắt follow
			autoFollow = false
			currentTarget = nil
			if followConn then followConn:Disconnect() followConn = nil end
			
			-- Thông báo tắt
			game.StarterGui:SetCore("SendNotification", {
				Title = "Stopped",
				Text = "Đã dừng Tele Follow",
				Duration = 1
			})
		else
			-- Bật follow
			local target = getClosestInFOV()
			if target then
				startFollow(target)
				game.StarterGui:SetCore("SendNotification", {
					Title = "Locked",
					Text = "Đang follow: " .. target.Parent.Name,
					Duration = 2
				})
			else
				game.StarterGui:SetCore("SendNotification", {
					Title = "❌ No Target",
					Text = "Không tìm thấy mục tiêu trong FOV!",
					Duration = 3
				})
			end
		end
	end
end)
