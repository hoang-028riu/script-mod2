-- Logic Tạo Slot
local function createSlot()
	slotCount = slotCount + 1
	local currentSlotIndex = slotCount
	slots[currentSlotIndex] = nil -- Init slot
	
	-- Container cho mỗi slot
	local slotFrame = Instance.new("Frame")
	slotFrame.Size = UDim2.new(1, 0, 0, 45)
	slotFrame.BackgroundColor3 = COLORS.ButtonDefault
	slotFrame.Parent = slotsContainer
	addCorner(slotFrame, 6)
	
	-- Số thứ tự
	local indexLabel = Instance.new("TextLabel")
	indexLabel.Text = "#" .. currentSlotIndex
	indexLabel.Size = UDim2.new(0, 30, 1, 0)
	indexLabel.BackgroundTransparency = 1
	indexLabel.TextColor3 = Color3.fromRGB(150, 150, 150)
	indexLabel.Font = Enum.Font.GothamBold
	indexLabel.TextSize = 18
	indexLabel.Parent = slotFrame
	
	-- Nút Lưu (Save)
	local btnSave = Instance.new("TextButton")
	btnSave.Text = "Lưu Tọa Độ"
	btnSave.Size = UDim2.new(0, 100, 0, 30)
	btnSave.Position = UDim2.new(0, 35, 0.5, -15) -- Căn giữa theo chiều dọc
	btnSave.BackgroundColor3 = COLORS.Accent
	btnSave.TextColor3 = Color3.new(1,1,1)
	btnSave.Font = Enum.Font.GothamBold
	btnSave.TextSize = 12
	btnSave.Parent = slotFrame
	addCorner(btnSave, 4)
	
	-- Nút Dịch chuyển (TP)
	local btnTP = Instance.new("TextButton")
	btnTP.Text = "Dịch Chuyển"
	btnTP.Size = UDim2.new(0, 100, 0, 30)
	btnTP.Position = UDim2.new(1, -105, 0.5, -15)
	btnTP.BackgroundColor3 = Color3.fromRGB(80, 80, 85) -- Màu xám (chưa có dữ liệu)
	btnTP.TextColor3 = Color3.fromRGB(180, 180, 180)
	btnTP.Font = Enum.Font.GothamBold
	btnTP.TextSize = 12
	btnTP.AutoButtonColor = false -- Tắt hiệu ứng nhấn khi chưa có data
	btnTP.Parent = slotFrame
	addCorner(btnTP, 4)
	
	-- Sự kiện Lưu
	btnSave.MouseButton1Click:Connect(function()
		character = player.Character or player.CharacterAdded:Wait()
		if character and character:FindFirstChild("HumanoidRootPart") then
			slots[currentSlotIndex] = character.HumanoidRootPart.Position
			
			-- Hiệu ứng UI khi lưu thành công
			btnSave.Text = "Đã Lưu!"
			btnSave.BackgroundColor3 = COLORS.Success
			
			-- Kích hoạt nút TP
			btnTP.BackgroundColor3 = COLORS.Warning
			btnTP.TextColor3 = Color3.fromRGB(30,30,30)
			btnTP.AutoButtonColor = true
			btnTP.Text = "TP Đến Đây"
			
			task.wait(1)
			btnSave.Text = "Ghi Đè"
			btnSave.BackgroundColor3 = COLORS.Accent
		end
	end)
	
	-- Sự kiện TP
	btnTP.MouseButton1Click:Connect(function()
		if slots[currentSlotIndex] then
			character = player.Character or player.CharacterAdded:Wait()
			if character and character:FindFirstChild("HumanoidRootPart") then
				character:MoveTo(slots[currentSlotIndex])
			end
		else
			-- Hiệu ứng báo lỗi nhẹ
			local originColor = btnTP.BackgroundColor3
			btnTP.Text = "Trống!"
			btnTP.BackgroundColor3 = COLORS.Danger
			task.wait(0.5)
			btnTP.Text = "Dịch Chuyển"
			btnTP.BackgroundColor3 = originColor
		end
	end)
	
	-- Cập nhật CanvasSize của thanh cuộn
	contentContainer.CanvasSize = UDim2.new(0, 0, 0, 0) -- Reset để tự động tính toán lại
end

