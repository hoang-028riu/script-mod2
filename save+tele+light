-- HỆ THỐNG XỬ LÝ ÁNH SÁNG
-------------------------------------------------------
local function updateLight()
	character = player.Character or player.CharacterAdded:Wait()
	local root = character:FindFirstChild("HumanoidRootPart")
	if not root then return end

	if not lightObject then
		lightObject = Instance.new("PointLight")
		lightObject.Name = "UserFlashlight"
		lightObject.Parent = root
		lightObject.Color = Color3.fromRGB(255, 250, 220)
		lightObject.Shadows = true
	end
	
	-- Đảm bảo đèn luôn theo người
	if lightObject.Parent ~= root then
		lightObject.Parent = root
	end

	lightObject.Range = lightRange
	lightObject.Brightness = lightLevel
end

