-- // LOGIC SLIDER //
local mouse = LocalPlayer:GetMouse()
local draggingSlider = false

local function UpdateSlider()
    local sliderPos = SliderBG.AbsolutePosition.X
    local sliderSize = SliderBG.AbsoluteSize.X
    local mousePos = mouse.X
    
    -- Tính toán phần trăm dựa trên vị trí chuột
    local percent = math.clamp((mousePos - sliderPos) / sliderSize, 0, 1)
    
    -- Cập nhật biến Power
    flingPower = math.floor(percent * maxPower)
    
    -- Cập nhật giao diện
    SliderFill.Size = UDim2.new(percent, 0, 1, 0)
    ValueLabel.Text = tostring(flingPower)
end

SliderButton.MouseButton1Down:Connect(function()
    draggingSlider = true
    UpdateSlider()
end)

UserInputService.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        draggingSlider = false
    end
end)

UserInputService.InputChanged:Connect(function(input)
    if draggingSlider and input.UserInputType == Enum.UserInputType.MouseMovement then
        UpdateSlider()
    end
end)

-- // CHỨC NĂNG FLING CHÍNH //

local function StartFling()
    local Character = LocalPlayer.Character
    if not Character then return end
    local RootPart = Character:FindFirstChild("HumanoidRootPart")
    if not RootPart then return end

    flinging = true
    
    ToggleButton.Text = "ON"
    ToggleButton.BackgroundColor3 = Color3.fromRGB(60, 255, 60)

    -- 1. Vật lý
    for _, child in pairs(Character:GetDescendants()) do
        if child:IsA("BasePart") then
            child.CustomPhysicalProperties = PhysicalProperties.new(100, 0.3, 0.5)
        end
    end

    -- 2. Noclip
    if noclipConnection then noclipConnection:Disconnect() end
    noclipConnection = RunService.Stepped:Connect(function()
        if flinging and Character then
            for _, v in pairs(Character:GetDescendants()) do
                if v:IsA("BasePart") then
                    v.CanCollide = false
                end
            end
        end
    end)

    -- 3. Tạo lực xoay
    local bambam = Instance.new("BodyAngularVelocity")
    bambam.Name = "FlingVelocity"
    bambam.Parent = RootPart
    bambam.AngularVelocity = Vector3.new(0, flingPower, 0) -- Sử dụng biến flingPower
    bambam.MaxTorque = Vector3.new(0, math.huge, 0)
    bambam.P = math.huge

    -- 4. Massless
    for i, v in next, Character:GetChildren() do
        if v:IsA("BasePart") then
            v.Massless = true
            v.Velocity = Vector3.new(0, 0, 0)
        end
    end

    -- 5. Loop (Cập nhật liên tục để đảm bảo xoay và nhận giá trị Power mới)
    task.spawn(function()
        while flinging and Character and RootPart and bambam.Parent do
            -- Cập nhật Power realtime từ thanh slider
            bambam.AngularVelocity = Vector3.new(0, flingPower, 0)
            task.wait(0.2)
            bambam.AngularVelocity = Vector3.new(0, 0, 0)
            task.wait(0.1)
        end
    end)
    
    local humanoid = Character:FindFirstChild("Humanoid")
    if humanoid then
        humanoid.Died:Connect(function()
            if flinging then StopFling() end
        end)
    end
end

function StopFling()
    flinging = false
    
    ToggleButton.Text = "OFF"
    ToggleButton.BackgroundColor3 = Color3.fromRGB(255, 60, 60)

    if noclipConnection then
        noclipConnection:Disconnect()
        noclipConnection = nil
    end

    local Character = LocalPlayer.Character
    if not Character then return end
    
    local RootPart = Character:FindFirstChild("HumanoidRootPart")
    if RootPart then
        for _, v in pairs(RootPart:GetChildren()) do
            if v.Name == "FlingVelocity" or v:IsA("BodyAngularVelocity") then
                v:Destroy()
            end
        end
        RootPart.Velocity = Vector3.new(0,0,0)
        RootPart.RotVelocity = Vector3.new(0,0,0)
    end

    for _, child in pairs(Character:GetDescendants()) do
        if child:IsA("BasePart") then
            child.CustomPhysicalProperties = PhysicalProperties.new(0.7, 0.3, 0.5)
            child.Massless = false
            child.CanCollide = true
        end
    end
end

ToggleButton.MouseButton1Click:Connect(function()
    if flinging then
        StopFling()
    else
        StartFling()
    end
end)

