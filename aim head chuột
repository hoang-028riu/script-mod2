-- Biến cấu hình
local aimEnabled = false
local fovValue = 30
local smoothing = 0.05 -- Giảm smoothing để ghim chắc hơn
local maxDistance = 500
local minDistance = 10
local lastCheckTime = 0
local checkInterval = 0.1
local currentTarget = nil
local toggleKey = Enum.KeyCode.F

-- Cập nhật giao diện
local function updateUI()
    toggleButton.Text = aimEnabled and "Aimbot: ON" or "Aimbot: OFF"
    toggleButton.BackgroundColor3 = aimEnabled and Color3.fromRGB(50, 200, 50) or Color3.fromRGB(200, 50, 50)
    fovLabel.Text = "FOV: " .. math.floor(fovValue) .. "°"
    
    local percentage = (fovValue - 10) / 90
    sliderHandle.Position = UDim2.new(percentage, -10, 0, -5)
    
    -- Cập nhật vòng FOV theo chuột
    local fovSize = fovValue * 5
    fovCircle.Size = UDim2.new(0, fovSize, 0, fovSize)
    fovCircle.Visible = aimEnabled
end

-- Tính toán góc giữa hai vector
local function getAngle(vector1, vector2)
    return math.deg(math.acos(vector1.Unit:Dot(vector2.Unit)))
end

-- Tìm đầu người chơi gần nhất trong FOV
local function findTarget()
    local cameraPos = camera.CFrame.Position
    local lookVector = camera.CFrame.LookVector
    local closestTarget = nil
    local closestAngle = fovValue
    
    for _, targetPlayer in pairs(Players:GetPlayers()) do
        if targetPlayer ~= player and targetPlayer.Character then
            local head = targetPlayer.Character:FindFirstChild("Head")
            if head then
                local headPos = head.Position
                local direction = (headPos - cameraPos).Unit
                local angle = getAngle(lookVector, direction)
                
                -- Kiểm tra khoảng cách từ đầu đến người chơi
                local distanceToPlayer = (headPos - player.Character.HumanoidRootPart.Position).Magnitude
                
                if angle <= fovValue and distanceToPlayer > minDistance then
                    local distance = (headPos - cameraPos).Magnitude
                    if distance <= maxDistance and angle < closestAngle then
                        closestTarget = head
                        closestAngle = angle
                    end
                end
            end
        end
    end
    
    return closestTarget
end

-- Di chuyển chuột đến vị trí (siêu chắc)
local function moveMouseTo(target)
    local targetPos = target.Position
    local vector = camera:WorldToScreenPoint(targetPos)
    
    if vector.Z > 0 then
        -- Di chuyển trực tiếp đến vị trí mà không dùng Lerp để ghim chắc hơn
        mousemoverel(vector.X - mouse.X, vector.Y - mouse.Y)
    end
end

-- Cập nhật vị trí vòng FOV theo chuột
local function updateFOVPosition()
    if aimEnabled then
        local fovSize = fovValue * 5
        fovCircle.Position = UDim2.new(0, mouse.X - fovSize/2, 0, mouse.Y - fovSize/2)
    end
end

-- Vòng lặp chính
RunService.RenderStepped:Connect(function()
    if aimEnabled then
        local currentTime = tick()
        
        -- Cập nhật mục tiêu định kỳ
        if currentTime - lastCheckTime > checkInterval then
            currentTarget = findTarget()
            lastCheckTime = currentTime
        end
        
        -- Di chuyển chuột đến mục tiêu
        if currentTarget and currentTarget.Parent then
            moveMouseTo(currentTarget)
        else
            currentTarget = nil
        end
        
        -- Cập nhật vị trí vòng FOV
        updateFOVPosition()
    end
end)

-- Xử lý nút bật/tắt
toggleButton.MouseButton1Click:Connect(function()
    aimEnabled = not aimEnabled
    updateUI()
end)

-- Xử lý thanh trượt FOV
local draggingSlider = false

fovSlider.MouseButton1Down:Connect(function()
    draggingSlider = true
end)

UserInputService.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        draggingSlider = false
    end
end)

UserInputService.InputChanged:Connect(function(input)
    if draggingSlider and input.UserInputType == Enum.UserInputType.MouseMovement then
        local sliderPos = fovSlider.AbsolutePosition.X
        local sliderSize = fovSlider.AbsoluteSize.X
        local mousePos = input.Position.X
        
        local percentage = math.clamp((mousePos - sliderPos) / sliderSize, 0, 1)
        fovValue = 10 + percentage * 90
        
        updateUI()
    end
    
    -- Cập nhật vị trí vòng FOV khi di chuyển chuột
    if aimEnabled then
        updateFOVPosition()
    end
end)

-- Xử lý ô nhập phím và nút áp dụng
applyButton.MouseButton1Click:Connect(function()
    local keyText = keyInput.Text:upper()
    
    -- Kiểm tra xem phím có hợp lệ không
    local success, keyCode = pcall(function()
        return Enum.KeyCode[keyText]
    end)
    
    if success and keyCode then
        toggleKey = keyCode
        applyButton.Text = "Đã lưu!"
        applyButton.BackgroundColor3 = Color3.fromRGB(50, 200, 50)
        
        -- Đặt lại sau 1 giây
        wait(1)
        applyButton.Text = "Áp dụng"
        applyButton.BackgroundColor3 = Color3.fromRGB(50, 100, 200)
    else
        applyButton.Text = "Lỗi!"
        applyButton.BackgroundColor3 = Color3.fromRGB(200, 50, 50)
        
        -- Đặt lại sau 1 giây
        wait(1)
        applyButton.Text = "Áp dụng"
        applyButton.BackgroundColor3 = Color3.fromRGB(50, 100, 200)
    end
end)

-- Bắt sự kiện nhấn phím
UserInputService.InputBegan:Connect(function(input, gameProcessed)
    if not gameProcessed and input.KeyCode == toggleKey then
        aimEnabled = not aimEnabled
        updateUI()
    end
end)

-- Khởi tạo giao diện
updateUI()
