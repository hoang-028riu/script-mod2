-- NOCLIP
local noclipConn = nil
local function startNoclip()
    if noclipConn then return end
    noclipConn = RunService.Stepped:Connect(function()
        local ch = LocalPlayer.Character
        if ch then
            for _, part in ipairs(ch:GetDescendants()) do
                if part:IsA("BasePart") then
                    pcall(function() part.CanCollide = false end)
                end
            end
        end
    end)
end
local function stopNoclip()
    if noclipConn then
        pcall(function() noclipConn:Disconnect() end)
        noclipConn = nil
    end
    local ch = LocalPlayer.Character
    if ch then
        for _, part in ipairs(ch:GetDescendants()) do
            if part:IsA("BasePart") then
                pcall(function() part.CanCollide = true end)
            end
        end
    end
end

-- FLY-TO (Tween to position behind target) - unchanged
local flyDebounce = false
local function flyToPlayerBehind(targetPlayer, duration)
    if flyDebounce then return end
    flyDebounce = true
    task.spawn(function()
        if not isAlive(targetPlayer) then flyDebounce = false; return end
        local tChar = targetPlayer.Character
        local myChar = LocalPlayer.Character
        if not tChar or not tChar:FindFirstChild("HumanoidRootPart") or not myChar or not myChar:FindFirstChild("HumanoidRootPart") then
            flyDebounce = false; return
        end

        local targetHRP = tChar.HumanoidRootPart
        local myHRP = myChar.HumanoidRootPart

        local behindCFrame = targetHRP.CFrame * CFrame.new(0, 0, -state.fly_offset_behind)
        local desiredCFrame = CFrame.new(behindCFrame.Position + Vector3.new(0, 1.4, 0), targetHRP.Position)

        local hum = myChar:FindFirstChildOfClass("Humanoid")
        local oldPlatformStand = nil
        if hum then
            oldPlatformStand = hum.PlatformStand
            hum.PlatformStand = true
        end

        local prevCanCollide = {}
        for _, part in ipairs(myChar:GetDescendants()) do
            if part:IsA("BasePart") then
                prevCanCollide[part] = part.CanCollide
                pcall(function() part.CanCollide = false end)
            end
        end

        local ok, createdTween = pcall(function()
            local info = TweenInfo.new(duration, Enum.EasingStyle.Sine, Enum.EasingDirection.Out)
            return TweenService:Create(myHRP, info, {CFrame = CFrame.new(behindCFrame.Position + Vector3.new(0, 1.4, 0))})
        end)

        if ok and createdTween then
            createdTween:Play()
            createdTween.Completed:Wait()
        else
            local start = myHRP.CFrame
            local targetCF = CFrame.new(behindCFrame.Position + Vector3.new(0, 1.4, 0))
            local t0 = tick()
            while tick() - t0 < duration do
                local alpha = (tick() - t0) / duration
                myHRP.CFrame = start:Lerp(targetCF, alpha)
                task.wait()
            end
            myHRP.CFrame = targetCF
        end

        for part, val in pairs(prevCanCollide) do
            pcall(function() part.CanCollide = val end)
        end
        if hum then
            hum.PlatformStand = oldPlatformStand or false
        end

        pcall(function()
            local camPos = myHRP.Position + Vector3.new(0, 2.0, 0)
            local lookAt = targetHRP.Position + Vector3.new(0, 1.0, 0)
            Camera.CFrame = CFrame.new(camPos, lookAt)
        end)

        flyDebounce = false
    end)
end

-- RENDER LOOP: AIM & FOV update (updated to use moving-parts-aware target finder)
RunService.RenderStepped:Connect(function()
    if fovCircle then
        local m = UserInputService:GetMouseLocation()
        fovCircle.Position = Vector2.new(m.X, m.Y)
        fovCircle.Radius = state.fov_radius
        fovCircle.Visible = state.fov_on
    end

    if state.aimbot and UserInputService:IsKeyDown(state.aim_key) then
        local targetInfo = findClosestTargetToCursor()
        if targetInfo then
            if targetInfo.type == "player" then
                local p = targetInfo.obj
                if p and isAlive(p) and p.Character and p.Character:FindFirstChild("Head") then
                    aimSmoothAtPos(p.Character.Head.Position, state.aim_smooth)
                end
            elseif targetInfo.type == "part" then
                local part = targetInfo.obj
                if part and part.Parent then
                    aimSmoothAtPos(part.Position, state.aim_smooth)
                end
            end
        end
    end
end)

