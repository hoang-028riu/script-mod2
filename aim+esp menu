    local teamFrame, teamBtn = makeToggleRow("Team-check (aim/list only other teams)", state.team_check, function(s)
        state.team_check = s
        refreshPlayerList()
    end)

    local noclipFrame, noclipBtn = makeToggleRow("Noclip", state.noclip_on, function(s)
        state.noclip_on = s
        if s then startNoclip() else stopNoclip() end
    end)

    -- NEW: controls for moving-part aiming
    makeToggleRow("Aimbot: include moving parts", state.aim_moving_parts, function(s) state.aim_moving_parts = s end)
    local _, velBox = makeTextboxRow("Moving velocity threshold (studs/s)", tostring(state.moving_vel_threshold), function(txt)
        local n = tonumber(txt)
        if n and n >= 0 then state.moving_vel_threshold = n end
    end)
    local _, anchoredBox = makeTextboxRow("Allow anchored parts? (true/false)", tostring(state.moving_part_allow_anchored), function(txt)
        local t = tostring(txt):lower()
        if t == "true" or t == "1" then state.moving_part_allow_anchored = true elseif t == "false" or t == "0" then state.moving_part_allow_anchored = false end
    end)
    local _, nameFilterBox = makeTextboxRow("Part name filter (opt)", tostring(state.moving_part_name_filter), function(txt)
        state.moving_part_name_filter = tostring(txt or "")
    end)

    local _, flyDurationBox = makeTextboxRow("Fly Duration (seconds)", tostring(state.fly_duration), function(txt)
        local n = tonumber(txt); if n and n > 0 then state.fly_duration = n end
    end)
    local _, flyOffsetBox = makeTextboxRow("Fly Behind Distance (studs)", tostring(state.fly_offset_behind), function(txt)
        local n = tonumber(txt); if n and n >= 0 then state.fly_offset_behind = n end
    end)

    local clearESPBtn = Instance.new("TextButton", leftScroll)
    clearESPBtn.Size = UDim2.new(1, -6, 0, 38)
    clearESPBtn.Text = "Remove All ESP"
    clearESPBtn.Font = Enum.Font.SourceSansBold
    clearESPBtn.TextSize = 14
    clearESPBtn.BackgroundColor3 = Color3.fromRGB(160,60,60)
    clearESPBtn.TextColor3 = Color3.new(1,1,1)
    local clearCorner = Instance.new("UICorner", clearESPBtn); clearCorner.CornerRadius = UDim.new(0,8)
    clearESPBtn.MouseButton1Click:Connect(function()
        toggleAllESP(false)
        state.esp_on = false
    end)

    -- Player row creator
    local function makePlayerRow(p)
        local frame = Instance.new("Frame", playerList)
        frame.Size = UDim2.new(1, -8, 0, 36)
        frame.BackgroundColor3 = Color3.fromRGB(44,44,54)
        local frameCorner = Instance.new("UICorner", frame); frameCorner.CornerRadius = UDim.new(0,8)

        local nameLabel = Instance.new("TextLabel", frame)
        nameLabel.Size = UDim2.new(0.6, -10, 1, 0)
        nameLabel.Position = UDim2.new(0, 8, 0, 0)
        nameLabel.BackgroundTransparency = 1
        nameLabel.Text = p.Name
        nameLabel.Font = Enum.Font.SourceSans
        nameLabel.TextSize = 14
        nameLabel.TextColor3 = Color3.fromRGB(230,230,230)
        nameLabel.TextXAlignment = Enum.TextXAlignment.Left

        local flyBtn = Instance.new("TextButton", frame)
        flyBtn.Size = UDim2.new(0.38, -12, 0.78, 0)
        flyBtn.Position = UDim2.new(0.62, 6, 0.11, 0)
        flyBtn.Text = "Fly Behind"
        flyBtn.Font = Enum.Font.SourceSansBold
        flyBtn.TextSize = 12
        flyBtn.BackgroundColor3 = Color3.fromRGB(80,120,200)
        flyBtn.TextColor3 = Color3.new(1,1,1)
        local flyCorner = Instance.new("UICorner", flyBtn); flyCorner.CornerRadius = UDim.new(0,6)

        flyBtn.MouseButton1Click:Connect(function()
            if isAlive(p) then
                flyToPlayerBehind(p, state.fly_duration)
            end
        end)

        playerButtonStore[p] = {Frame = frame, FlyBtn = flyBtn, NameLabel = nameLabel}
    end

    -- Refresh function (rebuild list)
    function refreshPlayerList()
        for _, child in ipairs(playerList:GetChildren()) do
            if child:IsA("Frame") then child:Destroy() end
        end
        playerButtonStore = {}
        local list = {}
        for _, p in ipairs(Players:GetPlayers()) do
            if isEnemy(p) then table.insert(list, p) end
        end
        table.sort(list, function(a,b) return a.Name:lower() < b.Name:lower() end)
        if #list == 0 then
            local lab = Instance.new("TextLabel", playerList)
            lab.Size = UDim2.new(1, -10, 0, 28)
            lab.Position = UDim2.new(0, 10, 0, 6)
            lab.BackgroundTransparency = 1
            lab.Text = "No players found for current filter."
            lab.Font = Enum.Font.SourceSans
            lab.TextSize = 13
            lab.TextColor3 = Color3.fromRGB(200,200,200)
        else
            for _, p in ipairs(list) do
                if isAlive(p) then
                    makePlayerRow(p)
                end
            end
        end
        task.wait(0.03)
        playerList.CanvasSize = UDim2.new(0, 0, 0, math.max(1, #list) * 44)
    end

    refreshBtn.MouseButton1Click:Connect(refreshPlayerList)

    spawn(function()
        while true do
            if state.team_check then refreshPlayerList() end
            task.wait(3)
        end
    end)

    refreshPlayerList()

    local resizeCorner = Instance.new("Frame", main)
    resizeCorner.Name = "ResizeCorner"
    resizeCorner.Size = UDim2.new(0, 18, 0, 18)
    resizeCorner.Position = UDim2.new(1, -20, 1, -20)
    resizeCorner.BackgroundColor3 = Color3.fromRGB(70,70,80)
    local rcCorner = Instance.new("UICorner", resizeCorner); rcCorner.CornerRadius = UDim.new(0, 6)
    resizeCorner.ZIndex = 100

    local grip = Instance.new("ImageLabel", resizeCorner)
    grip.Size = UDim2.new(1, -6, 1, -6)
    grip.Position = UDim2.new(0, 3, 0, 3)
    grip.Image = "rbxassetid://0"
    grip.BackgroundTransparency = 1

    do
        local resizing = false
        local startMousePos, startSize
        resizeCorner.InputBegan:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.MouseButton1 then
                resizing = true
                startMousePos = input.Position
                startSize = Vector2.new(main.AbsoluteSize.X, main.AbsoluteSize.Y)
                input.Changed:Connect(function()
                    if input.UserInputState == Enum.UserInputState.End then
                        resizing = false
                    end
                end)
            end
        end)
        UserInputService.InputChanged:Connect(function(input)
            if resizing and input.UserInputType == Enum.UserInputType.MouseMovement then
                local delta = input.Position - startMousePos
                local newW = math.clamp(startSize.X + delta.X, state.ui_min_size.X, state.ui_max_size.X)
                local newH = math.clamp(startSize.Y + delta.Y, state.ui_min_size.Y, state.ui_max_size.Y)
                main.Size = UDim2.new(0, newW, 0, newH)
            end
        end)
    end

    return {
        ScreenGui = screenGui,
        Main = main,
        LeftScroll = leftScroll,
        PlayerList = playerList,
        RefreshButton = refreshBtn,
        ResizeCorner = resizeCorner
    }
end

