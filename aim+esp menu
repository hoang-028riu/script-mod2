-- UTIL FUNCTIONS
local function isAlive(plr)
    if not plr then return false end
    if plr == LocalPlayer then return false end
    local c = plr.Character
    if not c then return false end
    local hum = c:FindFirstChildOfClass("Humanoid")
    if not hum or hum.Health <= 0 then return false end
    return true
end

local function getTeam(plr)
    if not plr then return nil end
    return plr.Team
end

local function isEnemy(plr)
    if not isAlive(plr) then return false end
    if not state.team_check then return true end
    local myTeam = getTeam(LocalPlayer)
    local theirTeam = getTeam(plr)
    return myTeam ~= theirTeam
end

local function worldToScreenVec(worldPos)
    local v3, onScreen = Camera:WorldToViewportPoint(worldPos)
    return Vector2.new(v3.X, v3.Y), onScreen, v3.Z
end

-- NEW: helper that checks if a part should be considered a moving target
local function isMovingPartCandidate(part)
    if not part or not part:IsA("BasePart") then return false end
    if part:IsDescendantOf(LocalPlayer.Character or workspace) and part:IsDescendantOf(LocalPlayer.Character) then return false end
    if not state.moving_part_allow_anchored and part.Anchored then return false end
    local vel = part.Velocity or Vector3.new(0,0,0)
    if vel.Magnitude < (tonumber(state.moving_vel_threshold) or 1) then return false end
    if state.moving_part_name_filter and state.moving_part_name_filter ~= "" then
        if not string.find(string.lower(part.Name), string.lower(state.moving_part_name_filter), 1, true) then
            return false
        end
    end
    -- exclude terrain, water, and joints-like parts by size check (very small debris can be included though)
    if part:IsA("Terrain") then return false end
    return true
end

-- NEW: find closest target to cursor among both players and moving parts
local function findClosestTargetToCursor()
    local mousePos = UserInputService:GetMouseLocation()
    local best, bestDist = nil, math.huge

    -- First consider players (keeps original behavior)
    for _, p in ipairs(Players:GetPlayers()) do
        if isEnemy(p) then
            local ch = p.Character
            if ch and ch:FindFirstChild("Head") then
                local screenPos, onScreen = worldToScreenVec(ch.Head.Position)
                if onScreen then
                    local d = (screenPos - mousePos).Magnitude
                    if state.fov_on then
                        if d <= state.fov_radius and d < bestDist then
                            bestDist, best = d, {type = "player", obj = p}
                        end
                    else
                        if d < bestDist then
                            bestDist, best = d, {type = "player", obj = p}
                        end
                    end
                end
            end
        end
    end

    -- Then consider moving parts if enabled
    if state.aim_moving_parts then
        -- iterate workspace descendants - but limit to avoid huge performance hit
        for _, part in ipairs(Workspace:GetDescendants()) do
            if part and part:IsA("BasePart") then
                -- skip parts under players' characters to avoid targeting player attachments unless intended
                if part:IsDescendantOf(LocalPlayer.Character or workspace) and part:IsDescendantOf(LocalPlayer.Character) then
                    -- skip
                else
                    if isMovingPartCandidate(part) then
                        -- screen position check
                        local screenPos, onScreen = worldToScreenVec(part.Position)
                        if onScreen then
                            local d = (screenPos - mousePos).Magnitude
                            if state.fov_on then
                                if d <= state.fov_radius and d < bestDist then
                                    bestDist, best = d, {type = "part", obj = part}
                                end
                            else
                                if d < bestDist then
                                    bestDist, best = d, {type = "part", obj = part}
                                end
                            end
                        end
                    end
                end
            end
        end
    end

    return best -- either nil or table {type="player"/"part", obj=...}
end

-- AIM FUNCTIONS (instant / smooth) - accepts world position
local function aimInstantAtPos(targetPos)
    Camera.CFrame = CFrame.new(Camera.CFrame.Position, targetPos)
end
local function aimSmoothAtPos(targetPos, smoothness)
    if not smoothness or smoothness <= 1 then
        aimInstantAtPos(targetPos)
        return
    end
    local cur = Camera.CFrame
    local desired = CFrame.new(cur.Position, targetPos)
    local alpha = 1 / smoothness
    Camera.CFrame = cur:Lerp(desired, alpha)
end

-- ESP: create/destroy Highlight instances (unchanged)
local function createHighlightForPlayer(plr)
    if not isAlive(plr) then return end
    if highlightStore[plr] and highlightStore[plr].Parent then return end
    local ok, h = pcall(function()
        local inst = Instance.new("Highlight")
        inst.Name = "ESP_Highlight_Custom"
        inst.Adornee = (plr.Character or nil)
        inst.Parent = workspace
        inst.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
        inst.FillColor = Color3.fromRGB(255, 90, 90)
        inst.FillTransparency = 0.65
        inst.OutlineColor = Color3.fromRGB(20,20,20)
        inst.OutlineTransparency = 0.7
        return inst
    end)
    if ok and h then highlightStore[plr] = h end
end

local function removeHighlightForPlayer(plr)
    local inst = highlightStore[plr]
    if inst then
        pcall(function() inst:Destroy() end)
        highlightStore[plr] = nil
    end
end

local function toggleAllESP(on)
    if on then
        for _, p in ipairs(Players:GetPlayers()) do
            if isAlive(p) then createHighlightForPlayer(p) end
        end
    else
        for p, _ in pairs(highlightStore) do
            removeHighlightForPlayer(p)
        end
    end
end

