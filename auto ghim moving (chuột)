-- Biến cấu hình
local aimEnabled = false
local fovValue = 30
local smoothing = 0.15
local maxDistance = 200
local minDistance = 5 -- Khoảng cách tối thiểu để không ngắm
local lastCheckTime = 0
local checkInterval = 0.3 -- Tăng thời gian kiểm tra để giảm lag
local currentTarget = nil
local movingParts = {}
local toggleKey = Enum.KeyCode.F -- Phím mặc định

-- Tối ưu hóa: Chỉ cập nhật danh sách vật thể khi cần
local function updateMovingParts()
    movingParts = {}
    -- Chỉ kiểm tra trong phạm vi gần để giảm tải
    for _, obj in pairs(Workspace:GetPartBoundsInRadius(camera.CFrame.Position, maxDistance)) do
        if obj:IsA("BasePart") and obj.Velocity.Magnitude > 0.5 then
            -- Không thêm vật thể của người chơi
            if not obj:IsDescendantOf(player.Character) then
                table.insert(movingParts, obj)
            end
        end
    end
end

-- Cập nhật giao diện
local function updateUI()
    toggleButton.Text = aimEnabled and "Aimbot: ON" or "Aimbot: OFF"
    toggleButton.BackgroundColor3 = aimEnabled and Color3.fromRGB(50, 200, 50) or Color3.fromRGB(200, 50, 50)
    fovLabel.Text = "FOV: " .. math.floor(fovValue) .. "°"
    
    local percentage = (fovValue - 10) / 90
    sliderHandle.Position = UDim2.new(percentage, -10, 0, -5)
    
    -- Cập nhật vòng FOV theo chuột
    local fovSize = fovValue * 5 -- Tỷ lệ 1:5
    fovCircle.Size = UDim2.new(0, fovSize, 0, fovSize)
    fovCircle.Visible = aimEnabled
end

-- Tính toán góc giữa hai vector
local function getAngle(vector1, vector2)
    return math.deg(math.acos(vector1.Unit:Dot(vector2.Unit)))
end

-- Lấy vị trí của người chơi
local function getPlayerPosition()
    if player.Character and player.Character:FindFirstChild("HumanoidRootPart") then
        return player.Character.HumanoidRootPart.Position
    end
    return camera.CFrame.Position
end

-- Tìm vật thể gần nhất trong FOV
local function findTarget()
    local cameraPos = camera.CFrame.Position
    local playerPos = getPlayerPosition()
    local lookVector = camera.CFrame.LookVector
    local closestTarget = nil
    local closestAngle = fovValue
    
    for _, obj in pairs(movingParts) do
        if obj and obj.Parent then
            local objPos = obj.Position
            local direction = (objPos - cameraPos).Unit
            local angle = getAngle(lookVector, direction)
            
            -- Kiểm tra khoảng cách từ vật thể đến người chơi
            local distanceToPlayer = (objPos - playerPos).Magnitude
            
            if angle <= fovValue and distanceToPlayer > minDistance then
                local distance = (objPos - cameraPos).Magnitude
                if distance <= maxDistance and angle < closestAngle then
                    closestTarget = obj
                    closestAngle = angle
                end
            end
        end
    end
    
    return closestTarget
end

-- Di chuyển chuột đến vị trí
local function moveMouseTo(target)
    local targetPos = target.Position
    local vector = camera:WorldToScreenPoint(targetPos)
    
    if vector.Z > 0 then
        local mousePos = Vector2.new(mouse.X, mouse.Y)
        local targetPos2D = Vector2.new(vector.X, vector.Y)
        local newPos = mousePos:Lerp(targetPos2D, smoothing)
        
        mousemoverel(newPos.X - mouse.X, newPos.Y - mouse.Y)
    end
end

-- Cập nhật vị trí vòng FOV theo chuột
local function updateFOVPosition()
    if aimEnabled then
        local fovSize = fovValue * 5
        fovCircle.Position = UDim2.new(0, mouse.X - fovSize/2, 0, mouse.Y - fovSize/2)
    end
end

-- Vòng lặp chính
RunService.Heartbeat:Connect(function()
    if aimEnabled then
        local currentTime = tick()
        
        -- Cập nhật danh sách vật thể đang di chuyển định kỳ
        if currentTime - lastCheckTime > checkInterval then
            updateMovingParts()
            lastCheckTime = currentTime
            
            -- Tìm mục tiêu mới
            currentTarget = findTarget()
        end
        
        -- Di chuyển chuột đến mục tiêu
        if currentTarget and currentTarget.Parent then
            moveMouseTo(currentTarget)
        else
            currentTarget = nil
        end
        
        -- Cập nhật vị trí vòng FOV
        updateFOVPosition()
    end
end)

-- Xử lý nút bật/tắt
