end)

-- Xử lý thanh trượt FOV
local draggingSlider = false

fovSlider.MouseButton1Down:Connect(function()
    draggingSlider = true
end)

UserInputService.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        draggingSlider = false
    end
end)

UserInputService.InputChanged:Connect(function(input)
    if draggingSlider and input.UserInputType == Enum.UserInputType.MouseMovement then
        local sliderPos = fovSlider.AbsolutePosition.X
        local sliderSize = fovSlider.AbsoluteSize.X
        local mousePos = input.Position.X
        
        local percentage = math.clamp((mousePos - sliderPos) / sliderSize, 0, 1)
        fovValue = 10 + percentage * 90
        
        updateUI()
    end
    
    -- Cập nhật vị trí vòng FOV khi di chuyển chuột
    if aimEnabled then
        updateFOVPosition()
    end
end)

