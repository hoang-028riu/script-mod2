-- // CHỨC NĂNG ESP (CORE) //

-- Xóa ESP cũ của 1 player
local function ClearESP(player)
    if ESP_Storage[player] then
        for _, obj in pairs(ESP_Storage[player]) do
            if obj.Remove then obj:Remove() else obj:Destroy() end
        end
        ESP_Storage[player] = nil
    end
end

-- Tạo ESP cho 1 player
local function CreateESP(player)
    if player == LocalPlayer then return end
    
    local storage = {
        Box = nil,
        Name = nil,
        Highlight = nil,
        Tracer = nil
    }
    
    -- 1. Highlight (Chams)
    local highlight = Instance.new("Highlight")
    highlight.Name = "ESPHighlight"
    highlight.FillColor = Color3.fromRGB(255, 0, 0)
    highlight.OutlineColor = Color3.fromRGB(255, 255, 255)
    highlight.FillTransparency = 0.5
    highlight.OutlineTransparency = 0
    highlight.Enabled = Settings.Chams_Enabled
    storage.Highlight = highlight

    -- 2. BillboardGui (Name & Box)
    local bb = Instance.new("BillboardGui")
    bb.Name = "ESP_Billboard"
    bb.Adornee = nil
    bb.AlwaysOnTop = true
    bb.Size = UDim2.new(4, 0, 5, 0)
    bb.StudsOffset = Vector3.new(0, 0, 0)
    
    local boxFrame = Instance.new("Frame")
    boxFrame.Size = UDim2.new(1, 0, 1, 0)
    boxFrame.BackgroundTransparency = 1
    boxFrame.BorderColor3 = Color3.new(1, 0, 0)
    boxFrame.BorderSizePixel = 2
    boxFrame.Visible = Settings.Box_Enabled
    boxFrame.Parent = bb
    storage.Box = boxFrame
    
    local nameLabel = Instance.new("TextLabel")
    nameLabel.Size = UDim2.new(1, 0, 0, 20)
    nameLabel.Position = UDim2.new(0, 0, -0.2, 0)
    nameLabel.BackgroundTransparency = 1
    nameLabel.Text = player.Name
    nameLabel.TextColor3 = Color3.new(1, 1, 1)
    nameLabel.TextStrokeTransparency = 0
    nameLabel.Visible = Settings.Name_Enabled
    nameLabel.Parent = bb
    storage.Name = nameLabel
    
    -- 3. Tracer (Drawing API) - Chỉ hoạt động nếu executor hỗ trợ Drawing
    local tracerLine
    if Drawing then
        tracerLine = Drawing.new("Line")
        tracerLine.Visible = false
        tracerLine.Color = Color3.new(1, 0, 0)
        tracerLine.Thickness = 1.5
        tracerLine.Transparency = 1
        storage.Tracer = tracerLine
    end
    
    ESP_Storage[player] = storage

    -- Loop Update cho từng Player
    local connection
    connection = RunService.RenderStepped:Connect(function()
        if not player.Character or not player.Character:FindFirstChild("HumanoidRootPart") then 
            if bb.Parent then bb.Parent = nil end
            if highlight.Parent then highlight.Parent = nil end
            if tracerLine then tracerLine.Visible = false end
            return 
        end
        
        local char = player.Character
        local hrp = char.HumanoidRootPart
        
        -- Update Chams
        if Settings.Chams_Enabled then
            if highlight.Parent ~= char then highlight.Parent = char end
            highlight.Enabled = true
        else
            highlight.Enabled = false
        end
        
        -- Update Box/Name
        if Settings.Box_Enabled or Settings.Name_Enabled then
            if bb.Parent ~= char then bb.Parent = char end
            boxFrame.Visible = Settings.Box_Enabled
            nameLabel.Visible = Settings.Name_Enabled
        else
            bb.Parent = nil
        end
        
        -- Update Tracers
        if tracerLine then
            if Settings.Tracers_Enabled then
                local vec, onScreen = Camera:WorldToViewportPoint(hrp.Position)
                if onScreen then
                    tracerLine.From = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y) -- Từ dưới màn hình
                    tracerLine.To = Vector2.new(vec.X, vec.Y)
                    tracerLine.Visible = true
                else
                    tracerLine.Visible = false
                end
            else
                tracerLine.Visible = false
            end
        end
        
        if not player.Parent then 
            ClearESP(player)
            connection:Disconnect()
        end
    end)
end

-- Refresh toàn bộ ESP
local function RefreshESP()
    for _, plr in pairs(Players:GetPlayers()) do
        ClearESP(plr)
        CreateESP(plr)
    end
end

Players.PlayerAdded:Connect(CreateESP)
Players.PlayerRemoving:Connect(ClearESP)

