-- 2. LOGIC XỬ LÝ PHÍM
local isRunning = false
local loopThread = nil
local currentKey = nil

-- Hàm chuyển đổi chuỗi thành Enum.KeyCode
local function getKeyCode(str)
	if str == " " or str:lower() == "space" then 
		return Enum.KeyCode.Space 
	end
	
	local upperStr = string.upper(str)
	local success, keycode = pcall(function()
		return Enum.KeyCode[upperStr]
	end)
	
	if success then 
		return keycode 
	end
	return nil
end

-- Hàm Bật/Tắt auto
local function toggleAuto()
	if isRunning then
		-- Tắt auto
		isRunning = false
		toggleBtn.Text = "Bắt đầu"
		toggleBtn.BackgroundColor3 = Color3.fromRGB(0, 170, 0)
		
		-- Nhả phím ra nếu đang giữ
		if currentKey then
			VirtualInputManager:SendKeyEvent(false, currentKey, false, game)
		end
		
		if loopThread then
			task.cancel(loopThread)
			loopThread = nil
		end
	else
		-- Bật auto
		local inputStr = textBox.Text
		if #inputStr == 0 then return end
		
		-- Chỉ lấy ký tự đầu tiên (nếu người dùng nhập nhiều chữ)
		if inputStr ~= "space" then
			inputStr = string.sub(inputStr, 1, 1)
		end
		
		local keyCode = getKeyCode(inputStr)
		if not keyCode then 
			textBox.Text = "Phím ko hợp lệ!"
			task.wait(1)
			textBox.Text = ""
			return 
		end
		
		currentKey = keyCode
		isRunning = true
		toggleBtn.Text = "Dừng"
		toggleBtn.BackgroundColor3 = Color3.fromRGB(170, 0, 0)
		
		-- Tạo vòng lặp nhấp nhả phím liên tục
		loopThread = task.spawn(function()
			while isRunning do
				-- Gửi lệnh nhấn phím xuống
				VirtualInputManager:SendKeyEvent(true, currentKey, false, game)
				task.wait(0.05) -- Thời gian giữ phím (có thể chỉnh nhỏ hơn để nhấp nhanh hơn)
				
				-- Gửi lệnh nhả phím lên
				VirtualInputManager:SendKeyEvent(false, currentKey, false, game)
				task.wait(0.05) -- Thời gian nghỉ giữa 2 lần nhấn
			end
		end)
	end
end

toggleBtn.MouseButton1Click:Connect(toggleAuto)
