--✨ Hiệu ứng tia sáng sau lưng
local function createTrail(hrp)
	-- Tạo 2 attachment: 1 ở giữa, 1 lùi về sau lưng
	local attach1 = Instance.new("Attachment", hrp)
	attach1.Position = Vector3.new(0, 1, 0)
	local attach2 = Instance.new("Attachment", hrp)
	attach2.Position = Vector3.new(0, 1, 3)

	local trail = Instance.new("Trail")
	trail.Attachment0 = attach1
	trail.Attachment1 = attach2
	trail.Lifetime = 0.4
	trail.Color = ColorSequence.new(Color3.fromRGB(0,200,255), Color3.fromRGB(255,255,255))
	trail.Transparency = NumberSequence.new(0.1, 1)
	trail.LightEmission = 1
	trail.Enabled = true
	trail.Parent = hrp

	-- Tạo ánh sáng khi lướt
	local light = Instance.new("PointLight", hrp)
	light.Color = Color3.fromRGB(0, 200, 255)
	light.Brightness = 5
	light.Range = 10

	Debris:AddItem(trail, 0.6)
	Debris:AddItem(attach1, 0.6)
	Debris:AddItem(attach2, 0.6)
	Debris:AddItem(light, 0.6)
end

--⚡ Dash function
local function dash(hrp)
	if not canDash then return end
	canDash = false

	createTrail(hrp)

	local lookVector = hrp.CFrame.LookVector
	local targetPos = hrp.Position + (lookVector * dashDistance)
	local tween = TweenService:Create(hrp, TweenInfo.new(0.25, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {CFrame = CFrame.new(targetPos, targetPos + lookVector)})
	tween:Play()

	local timeLeft = cooldownTime
	cdText.Text = tostring(timeLeft)
	cdCircle.Size = UDim2.new(1,0,1,0)

	while timeLeft > 0 do
		task.wait(1)
		timeLeft -= 1
		cdText.Text = timeLeft > 0 and tostring(timeLeft) or "Q"
		cdCircle.Size = UDim2.new(timeLeft/cooldownTime, 0, timeLeft/cooldownTime, 0)
	end

	canDash = true
end

--🎮 Nhấn Q để kích hoạt
UIS.InputBegan:Connect(function(input, gpe)
	if gpe then return end
	if input.KeyCode == Enum.KeyCode.Q and canDash then
		local char = player.Character
		if char and char:FindFirstChild("HumanoidRootPart") then
			dash(char.HumanoidRootPart)
		end
	end
end)

